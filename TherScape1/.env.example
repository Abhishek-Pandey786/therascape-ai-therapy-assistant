# TheraScape Environment Configuration

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Java Backend Configuration
JAVA_BACKEND_URL=http://localhost:8080
JAVA_BACKEND_TIMEOUT=10
ENABLE_JAVA_BACKEND=true

# Flask Configuration
SECRET_KEY=therscape-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=true

# Feature Flags
ENABLE_VIDEO_RECOMMENDATIONS=true
ENABLE_USER_AUTHENTICATION=true
ENABLE_MOOD_ANALYSIS=true

# Session Configuration
SESSION_TIMEOUT=3600
PERMANENT_SESSION_LIFETIME=3600

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Database Configuration (if needed for Flask)
DATABASE_URL=sqlite:///therscape.db

# Security Settings
JWT_SECRET_KEY=jwt-secret-key-change-this
JWT_ACCESS_TOKEN_EXPIRES=3600

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
